{
  "name": "fantasy-map-generator",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.app.json --noEmit && vite build",
    "lint": "oxlint --tsconfig tsconfig.app.json .",
    "lint:fix": "oxlint --tsconfig tsconfig.app.json --fix .",
    "format": "oxfmt --check .",
    "format:write": "oxfmt .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@mantine/core": "^8.3.16",
    "@mantine/hooks": "^8.3.16",
    "@tabler/icons-react": "^3.40.0",
    "clsx": "^2.1.1",
    "i18next": "^25.8.17",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.6",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@webgpu/types": "^0.1.69",
    "autoprefixer": "^10.4.27",
    "oxfmt": "^0.37.0",
    "oxlint": "^1.52.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "packageManager": "pnpm@10.6.5",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
